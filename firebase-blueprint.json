{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "premiumUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Song": {
      "title": "Song",
      "description": "Music track metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "url": { "type": "string" },
        "coverUrl": { "type": "string" },
        "duration": { "type": "number" }
      },
      "required": ["title", "artist", "url"]
    },
    "Like": {
      "title": "Like",
      "description": "User's liked song",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "songId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Collection of available songs"
    },
    "/users/{userId}/likes/{songId}": {
      "schema": "Like",
      "description": "User's liked songs collection"
    }
  }
}
